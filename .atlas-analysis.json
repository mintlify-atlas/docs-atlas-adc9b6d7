  "keyFeatures": [
    "Layer-stack architecture for composable update and event processing",
    "Flexible event system with type identification and category bitmask filtering",
    "2D batch renderer using OpenGL with quad drawing and texture support",
    "Entity Component System (ECS) backed by the entt library",
    "Structured logging with spdlog for core and client loggers",
    "ImGui integration for real-time debugging overlays",
    "Orthographic camera with controller abstraction",
    "Multi-project build setup using Premake5",
    "Stag editor application built on the engine layer system",
    "Precompiled header support and clean include structure"
  ],
